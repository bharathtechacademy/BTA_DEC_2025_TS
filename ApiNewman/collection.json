    {
      "name": "Create a duplicate repository for the authenticated user",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Verify the status code\r",
              "pm.test(\"Verify Status Code of Duplicate Repo Request\", function(){\r",
              "    pm.expect(pm.response.code).to.eql(422);\r",
              "})\r",
              "\r",
              "//Verify the status message\r",
              "pm.test(\"Verify Status message of Duplicate Repo Request\", function(){\r",
              "    pm.expect(pm.response.status).to.eql(\"Unprocessable Entity\");\r",
              "})\r",
              "\r",
              "//Verify the response time\r",
              "pm.test(\"Verify Response Time of Duplicate Repo Request\", function(){\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "})\r",
              "\r",
              "//Verify the Response Body\r",
              "pm.test(\"Verify Response Body for Duplicate Repo Request\", function () {\r",
              "    pm.expect(pm.response.json().message).to.eql(\"Repository creation failed.\");\r",
              "    pm.expect(pm.response.json().errors[0].message).to.eql(\"name already exists on this account\");\r",
              "    pm.expect(pm.response.json().status).to.eql(\"422\");\r",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "accept",
            "value": "application/vnd.github+json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "{{Token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\": \"JMeterRepo\",\r\n    \"description\": \"Sample Duplicate Repo From Postman\",\r\n    \"private\": false\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{BaseUrl}}/user/repos",
          "host": [
            "{{BaseUrl}}"
          ],
          "path": [
            "user",
            "repos"
          ]
        }
      },
      "response": []
    },
